# Server Configuration
PORT=3000
NODE_ENV=development
WEBHOOK_SECRET=your-secret-key-here

# DATEV Credentials
DATEV_USERNAME=your-datev-username
DATEV_PASSWORD=your-datev-password
DATEV_URL=https://unternehmen-online.datev.de

# Google Service Account (path to JSON file)
GOOGLE_SERVICE_ACCOUNT_PATH=./service-account.json

# Apps Script Webhook URL (for status callbacks)
APPS_SCRIPT_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/exec

# File Processing
MAX_FILE_SIZE_MB=10
UPLOAD_TIMEOUT_MS=60000
